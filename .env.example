# PostHog(https://posthog.com) 프로젝트 API 키 (선택)
# 비워두면 분석 SDK가 로드되지 않으며 앱 동작에는 영향 없음
NEXT_PUBLIC_POSTHOG_KEY=
# EU 리전 등 다른 호스트 사용 시 설정 (기본: https://us.i.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=

# 카카오 개발자 콘솔(https://developers.kakao.com)에서 발급한 JavaScript 키
# [앱] → [플랫폼 키] → JavaScript 키
# [JavaScript SDK 도메인]에 http://localhost:3000 등록 필요 (Web 플랫폼 등록과 별도)
# [제품 설정] → [카카오맵] → 활성화 ON
NEXT_PUBLIC_KAKAO_MAP_API_KEY=
